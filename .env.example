# Copie este arquivo para ".env" e preencha com os valores do seu projeto Supabase
# (Dashboard > Project Settings > API)

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave pública VAPID, usada pelo navegador para se inscrever em notificações push.
# Gere o par de chaves com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=sua-chave-publica-vapid-aqui
